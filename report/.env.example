# Copie ce fichier en ./report/.env (chmod 600, jamais commité).
# Laisse NOTIFY_WEBHOOK vide pour ne pas notifier (les confirmations sont juste logguées).

# Discord  : URL du webhook du salon (Param. salon > Intégrations > Webhooks).
# Telegram : https://api.telegram.org/bot<TOKEN>/sendMessage?chat_id=<CHAT_ID>  (+ NOTIFY_KIND=telegram)
NOTIFY_WEBHOOK=
NOTIFY_KIND=discord

# Optionnel (Discord) : user ID à mentionner/ping dans la notif.
NOTIFY_MENTION=

# Seuil de confirmation déclenchant UNE notification par domaine.
NOTIFY_THRESHOLD=2

# Rate limiting (défauts : 10 req / IP / heure).
RL_MAX=10
RL_WINDOW_MS=3600000
